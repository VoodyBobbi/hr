# Пример конфигурации переменных окружения для системы логирования

# Путь к файлу БД SQLite
# По умолчанию: logs/logs.db
# FAQ_LOGS_DB=C:\Users\Home\Desktop\Work files\faq-assistant\logs\logs.db

# Ретеншен логов в днях (логи старше этого будут удаляться)
# По умолчанию: 30
FAQ_LOG_RETENTION_DAYS=30

# Включить WAL-режим для SQLite (улучшает параллелизм)
# По умолчанию: true
FAQ_ENABLE_WAL=true

# Таймаут при занятой БД в секундах
# По умолчанию: 10
FAQ_DB_TIMEOUT=10

# Маскировать ли чувствительные данные в логах
# (будут заменены на первый и последний символ + звёздочки)
# По умолчанию: false
FAQ_MASK_SENSITIVE_DATA=false

